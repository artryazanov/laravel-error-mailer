{
    "name": "artryazanov/laravel-error-mailer",
    "description": "A Laravel package for sending detailed error information via email.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Artem Ryazanov",
            "email": "artryazanov@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/mail": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Artryazanov\\ErrorMailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Artryazanov\\ErrorMailer\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Artryazanov\\ErrorMailer\\ErrorMailerServiceProvider"
            ],
            "aliases": {
                "ErrorMailer": "Artryazanov\\ErrorMailer\\Facades\\ErrorMailer"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
